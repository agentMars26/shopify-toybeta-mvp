<section class="section">
  <div class="page-width">
    <div class="section-heading">
      <div>
        {% if section.settings.eyebrow != blank %}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{% endif %}
        <h2>{{ section.settings.heading }}</h2>
      </div>
    </div>
    <div class="feature-grid">
      {% for block in section.blocks %}
        <article class="feature-tile" {{ block.shopify_attributes }}>
          <div class="eyebrow">{{ block.settings.kicker }}</div>
          <h3>{{ block.settings.heading }}</h3>
          <div class="text-muted">{{ block.settings.text }}</div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Feature columns",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why it converts" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built for hype launches and evergreen catalog sales" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "Merchandising" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Story-driven product cards" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Highlight drop urgency, color variants, and collectible tiers without clutter.</p>" }
      ]
    }
  ],
  "presets": [{ "name": "Feature columns", "blocks": [{ "type": "feature" }, { "type": "feature", "settings": { "kicker": "Trust", "heading": "Reviews and guarantees", "text": "<p>Show social proof, shipping reassurance, and preorder clarity.</p>" } }, { "type": "feature", "settings": { "kicker": "Retention", "heading": "Email capture that feels native", "text": "<p>Invite collectors into restock alerts, VIP drops, and factory partnerships.</p>" } }] }]
}
{% endschema %}
