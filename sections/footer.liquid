<footer class="site-footer section">
  <div class="page-width footer-shell">
    <div>
      <div class="brand">{{ shop.name }}</div>
      <p class="footer-note">{{ settings.footer_note }}</p>
    </div>
    <div class="footer-note">
      <div>{{ shop.email }}</div>
      <div>{{ shop.address.city }}{% if shop.address.country != blank %}, {{ shop.address.country }}{% endif %}</div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
