<section class="hero">
  <div class="page-width">
    <div class="hero-card">
      <div>
        {% if section.settings.eyebrow != blank %}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{% endif %}
        <h1>{{ section.settings.heading }}</h1>
        <div class="text-muted hero-copy">{{ section.settings.subtext }}</div>
        <div class="hero-actions">
          {% if section.settings.primary_label != blank %}<a class="btn btn-primary" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>{% endif %}
          {% if section.settings.secondary_label != blank %}<a class="btn btn-secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>{% endif %}
        </div>
        <div class="hero-trust-row">
          <span class="hero-chip">⭐ Premium unboxing flow</span>
          <span class="hero-chip">🚚 Clear preorder timing</span>
          <span class="hero-chip">📱 Mobile-first browse path</span>
        </div>
        <div class="hero-metrics">
          {% for block in section.blocks %}
            <div class="metric" {{ block.shopify_attributes }}>
              <div class="eyebrow">{{ block.settings.label }}</div>
              <div class="h3">{{ block.settings.value }}</div>
            </div>
          {% endfor %}
        </div>
      </div>
      <div class="hero-media">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'eager', sizes: '(min-width: 990px) 40vw, 100vw' }}
        {% else %}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero banner",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Toybeta-inspired demo" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Blind box energy, optimized for conversion." },
    { "type": "richtext", "id": "subtext", "label": "Subtext", "default": "<p>Create a vibrant storefront for collectible figures, limited drops, and toy launches.</p>" },
    { "type": "text", "id": "primary_label", "label": "Primary button label", "default": "Shop new arrivals" },
    { "type": "url", "id": "primary_link", "label": "Primary button link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "Browse collections" },
    { "type": "url", "id": "secondary_link", "label": "Secondary button link" },
    { "type": "image_picker", "id": "image", "label": "Image" }
  ],
  "blocks": [
    {
      "type": "metric",
      "name": "Metric",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Sell-through" },
        { "type": "text", "id": "value", "label": "Value", "default": "92% in 14 days" }
      ]
    }
  ],
  "presets": [{ "name": "Hero banner", "blocks": [{ "type": "metric" }, { "type": "metric", "settings": { "label": "Average order", "value": "$74" } }, { "type": "metric", "settings": { "label": "Repeat buyers", "value": "38%" } }] }]
}
{% endschema %}
