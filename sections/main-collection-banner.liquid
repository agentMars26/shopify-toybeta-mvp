<section class="section" style="padding-bottom:1rem;">
  <div class="page-width">
    <div class="collection-banner-card">
      <div>
        <div class="eyebrow">Collection</div>
        <h1>{{ collection.title }}</h1>
        {% if collection.description != blank %}
          <div class="text-muted collection-banner-copy">{{ collection.description }}</div>
        {% else %}
          <div class="text-muted collection-banner-copy"><p>Use this banner to frame the assortment, explain artist or drop context, and reassure shoppers what to expect in the mix.</p></div>
        {% endif %}
        <div class="hero-trust-row">
          <span class="hero-chip">Blind boxes</span>
          <span class="hero-chip">Limited figures</span>
          <span class="hero-chip">Gift-ready picks</span>
        </div>
      </div>
      <div class="collection-banner-stats">
        <div class="collection-stat">
          <div class="eyebrow">Assortment</div>
          <strong>{{ collection.products_count }} items</strong>
          <div class="text-muted">Mix bestseller anchors with fresh drops.</div>
        </div>
        <div class="collection-stat">
          <div class="eyebrow">Merchandising</div>
          <strong>Price ladder</strong>
          <div class="text-muted">Make entry, core, and premium tiers obvious.</div>
        </div>
        <div class="collection-stat">
          <div class="eyebrow">Mobile flow</div>
          <strong>Fast browse</strong>
          <div class="text-muted">Filters and cards collapse cleanly for handheld review.</div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main collection banner",
  "settings": []
}
{% endschema %}
