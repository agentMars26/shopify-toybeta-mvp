{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign threshold_shipping = section.settings.free_shipping_threshold | times: 100
  assign threshold_gift = section.settings.free_gift_threshold | times: 100
  assign add_on_metafield = blank
  assign add_on_metafield_namespace = section.settings.add_on_metafield_namespace | default: settings.default_add_on_metafield_namespace
  assign add_on_metafield_key = section.settings.add_on_metafield_key | default: settings.default_add_on_metafield_key

  if section.settings.add_on_source == 'metafield' and add_on_metafield_namespace != blank and add_on_metafield_key != blank
    assign add_on_metafield = product.metafields[add_on_metafield_namespace][add_on_metafield_key]
  endif

  assign add_on_product = blank
  if add_on_metafield != blank and add_on_metafield.type == 'product_reference'
    assign add_on_product = add_on_metafield.value
  endif
%}

<section class="section">
  <div class="page-width product-layout">
    <div class="product-gallery">
      <div class="product-gallery-main">
        {% if product.featured_media != blank %}
          {{ product.featured_media | image_url: width: 1200 | image_tag: alt: product.title }}
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>
      {% if product.images.size > 1 %}
        <div class="product-thumbs">
          {% for image in product.images limit: 4 %}
            {{ image | image_url: width: 400 | image_tag: alt: product.title }}
          {% endfor %}
        </div>
      {% endif %}

      <div class="product-detail-grid">
        <article class="product-detail-card">
          <div class="eyebrow">Merchandising note</div>
          <h3>Lead with the hero SKU</h3>
          <div class="text-muted"><p>Reserve the first image for the cleanest silhouette or packaging shot, then use detail frames to reinforce value.</p></div>
        </article>
        <article class="product-detail-card">
          <div class="eyebrow">Drop strategy</div>
          <h3>Bundle-friendly copy</h3>
          <div class="text-muted"><p>Call out mystery rate, character lineup, or artist story in a way that nudges multi-item carts.</p></div>
        </article>
        <article class="product-detail-card">
          <div class="eyebrow">Mobile UX</div>
          <h3>Sticky purchase panel</h3>
          <div class="text-muted"><p>Details stay readable while the form remains close to the primary add-to-cart action.</p></div>
        </article>
      </div>
    </div>

    <div class="product-panel">
      <div class="product-heading">
        <div>
          {% if product.vendor != blank %}<div class="eyebrow">{{ product.vendor }}</div>{% endif %}
          <h1>{{ product.title }}</h1>
        </div>
        <div class="badge badge-outline">{% if product.available %}Ready to ship{% else %}Preorder{% endif %}</div>
      </div>

      <div>
        <span class="price">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}<span class="compare-at">{{ product.compare_at_price | money }}</span>{% endif %}
      </div>

      <div class="product-status-row">
        {% for block in section.blocks %}
          {% if block.type == 'trust_chip' %}
            <span class="hero-chip" {{ block.shopify_attributes }}>{{ block.settings.label }}</span>
          {% endif %}
        {% endfor %}
      </div>

      {% if product.description != blank %}
        <div class="text-muted product-description">{{ product.description }}</div>
      {% endif %}

      {% form 'product', product, class: 'product-form', data-product-form: '' %}
        {% unless product.has_only_default_variant %}
          <div class="option-group">
            <label for="Variant-{{ section.id }}">Edition</label>
            <select class="select" id="Variant-{{ section.id }}" name="id">
              {% for variant in product.variants %}
                <option value="{{ variant.id }}" {% if variant.id == current_variant.id %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}>
                  {{ variant.title }} • {{ variant.price | money }}{% unless variant.available %} • Sold out{% endunless %}
                </option>
              {% endfor %}
            </select>
          </div>
        {% else %}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
        {% endunless %}

        <div class="product-actions">
          <input class="input" id="Quantity-{{ section.id }}" type="number" min="1" value="1" name="quantity" data-qty-input aria-label="Quantity">
          <button class="btn btn-primary" type="submit" {% unless product.available %}disabled{% endunless %}>{% if product.available %}Add to cart{% else %}Sold out{% endif %}</button>
        </div>
      {% endform %}

      <div class="product-threshold-panel">
        <div class="product-threshold-row">
          <div>
            <div class="eyebrow">{{ section.settings.threshold_eyebrow }}</div>
            <strong>{{ section.settings.threshold_heading }}</strong>
          </div>
          <span class="badge badge-outline">{{ section.settings.threshold_badge }}</span>
        </div>
        <div class="progress-track" aria-hidden="true"><span class="progress-fill" style="width: {{ section.settings.threshold_progress }}%"></span></div>
        <div class="text-muted"><p>{{ section.settings.threshold_copy | replace: '[free_shipping]', threshold_shipping | money | replace: '[free_gift]', threshold_gift | money }}</p></div>
        <div class="product-threshold-grid">
          <div class="product-threshold-card">
            <strong>{{ section.settings.threshold_card_one_title }}</strong>
            <span class="text-muted">{{ section.settings.threshold_card_one_copy }}</span>
          </div>
          <div class="product-threshold-card">
            <strong>{{ section.settings.threshold_card_two_title }}</strong>
            <span class="text-muted">{{ section.settings.threshold_card_two_copy }}</span>
          </div>
        </div>
      </div>

      <div class="mini-cart-panel">
        <div class="mini-cart-header">
          <div>
            <div class="eyebrow">Cart preview</div>
            <strong>Mini cart / drawer pattern</strong>
          </div>
          <button class="btn btn-secondary" type="button" data-cart-toggle>Open cart</button>
        </div>
        <div class="text-muted"><p>This now points at the shared drawer and is ready for a lightweight Ajax add-to-cart handoff in the theme scaffold.</p></div>
      </div>

      <div class="mini-cart-panel">
        <div class="mini-cart-header">
          <div>
            <div class="eyebrow">{{ section.settings.add_on_eyebrow }}</div>
            <strong>{{ section.settings.add_on_heading }}</strong>
          </div>
          <span class="badge badge-outline">{{ section.settings.add_on_badge }}</span>
        </div>
        {% if section.settings.add_on_intro != blank %}
          <div class="text-muted"><p>{{ section.settings.add_on_intro }}</p></div>
        {% endif %}
        {% if section.settings.add_on_source == 'metafield' %}
          <div class="text-muted quick-add-copy"><p>Source mode: product metafield <code>{{ add_on_metafield_namespace }}.{{ add_on_metafield_key }}</code>. Until admin wiring exists, the manual cards below stay as preview-safe fallbacks.</p></div>
        {% endif %}
        <div class="quick-add-stack">
          {% if add_on_product != blank %}
            {% assign add_on_variant = add_on_product.selected_or_first_available_variant %}
            <article class="drawer-item">
              <div class="drawer-thumb">
                {% if add_on_product.featured_image %}
                  {{ add_on_product.featured_image | image_url: width: 240 | image_tag: alt: add_on_product.title }}
                {% else %}
                  {{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>
              <div>
                <div class="drawer-item-row"><strong>{{ add_on_product.title }}</strong><span>{% if add_on_variant %}{{ add_on_variant.price | money }}{% endif %}</span></div>
                <div class="text-muted">{{ add_on_product.description | strip_html | truncate: 120 }}</div>
                {% if add_on_variant %}
                  {% form 'product', add_on_product, class: 'quick-add-form', data-product-form: '' %}
                    <input type="hidden" name="id" value="{{ add_on_variant.id }}">
                    <input type="hidden" name="quantity" value="1">
                    <button class="btn btn-secondary" type="submit" {% unless add_on_variant.available %}disabled{% endunless %}>{{ section.settings.add_on_cta_label }}</button>
                  {% endform %}
                {% endif %}
              </div>
            </article>
          {% endif %}

          {% for block in section.blocks %}
            {% if block.type == 'add_on_card' %}
              <article class="drawer-item" {{ block.shopify_attributes }}>
                <div class="drawer-thumb">
                  {% if block.settings.image != blank %}
                    {{ block.settings.image | image_url: width: 240 | image_tag: alt: block.settings.title }}
                  {% elsif product.featured_image %}
                    {{ product.featured_image | image_url: width: 240 | image_tag: alt: product.title }}
                  {% else %}
                    {{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}
                </div>
                <div>
                  <div class="drawer-item-row"><strong>{{ block.settings.title }}</strong><span>{{ block.settings.price }}</span></div>
                  <div class="text-muted">{{ block.settings.copy }}</div>
                  <div class="quick-add-copy">{{ block.settings.source_note }}</div>
                  <button class="btn btn-secondary" type="button" disabled>{{ block.settings.cta_label }}</button>
                </div>
              </article>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="product-benefits">
        {% for block in section.blocks %}
          {% if block.type == 'benefit' %}
            <article class="product-benefit" {{ block.shopify_attributes }}>
              <div class="badge">{{ block.settings.badge }}</div>
              <div class="text-muted"><p>{{ block.settings.copy }}</p></div>
            </article>
          {% endif %}
        {% endfor %}
      </div>

      <ul class="product-checklist">
        {% for block in section.blocks %}
          {% if block.type == 'checklist_item' %}
            <li {{ block.shopify_attributes }}><span>{{ block.settings.label }}</span><span class="filter-token">{{ block.settings.status }}</span></li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main product",
  "settings": [
    {
      "type": "select",
      "id": "add_on_source",
      "label": "Add-on source",
      "default": "manual",
      "options": [
        { "value": "manual", "label": "Section blocks only" },
        { "value": "metafield", "label": "Product metafield with block fallback" }
      ]
    },
    {
      "type": "text",
      "id": "add_on_eyebrow",
      "label": "Add-on eyebrow",
      "default": "Quick add idea"
    },
    {
      "type": "text",
      "id": "add_on_heading",
      "label": "Add-on heading",
      "default": "Keep a nearby add-on visible"
    },
    {
      "type": "text",
      "id": "add_on_badge",
      "label": "Add-on badge",
      "default": "Collection-safe"
    },
    {
      "type": "textarea",
      "id": "add_on_intro",
      "label": "Add-on intro",
      "default": "Use this area for a real accessory product, premium packaging, or creator bonus item."
    },
    {
      "type": "text",
      "id": "add_on_cta_label",
      "label": "Live add-on CTA label",
      "default": "Add add-on"
    },
    {
      "type": "text",
      "id": "add_on_metafield_namespace",
      "label": "Add-on metafield namespace",
      "default": "custom"
    },
    {
      "type": "text",
      "id": "add_on_metafield_key",
      "label": "Add-on metafield key",
      "default": "product_add_on"
    },
    {
      "type": "text",
      "id": "threshold_eyebrow",
      "label": "Threshold eyebrow",
      "default": "Cart momentum"
    },
    {
      "type": "text",
      "id": "threshold_heading",
      "label": "Threshold heading",
      "default": "Use thresholds to make the next action feel obvious"
    },
    {
      "type": "text",
      "id": "threshold_badge",
      "label": "Threshold badge",
      "default": "AOV nudge"
    },
    {
      "type": "range",
      "id": "threshold_progress",
      "label": "Preview progress percent",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 62,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "free_shipping_threshold",
      "label": "Free shipping threshold",
      "min": 25,
      "max": 500,
      "step": 5,
      "default": 75,
      "unit": "$"
    },
    {
      "type": "range",
      "id": "free_gift_threshold",
      "label": "Free gift threshold",
      "min": 25,
      "max": 500,
      "step": 5,
      "default": 90,
      "unit": "$"
    },
    {
      "type": "textarea",
      "id": "threshold_copy",
      "label": "Threshold copy",
      "default": "Message the next reward clearly: free shipping at [free_shipping], then a collector gift at [free_gift]. This works especially well right above the cart handoff."
    },
    {
      "type": "text",
      "id": "threshold_card_one_title",
      "label": "Threshold card 1 title",
      "default": "Free shipping"
    },
    {
      "type": "text",
      "id": "threshold_card_one_copy",
      "label": "Threshold card 1 copy",
      "default": "Reduce hesitation with a reachable first unlock."
    },
    {
      "type": "text",
      "id": "threshold_card_two_title",
      "label": "Threshold card 2 title",
      "default": "Collector gift"
    },
    {
      "type": "text",
      "id": "threshold_card_two_copy",
      "label": "Threshold card 2 copy",
      "default": "Turn one-item carts into bundle behavior."
    }
  ],
  "blocks": [
    {
      "type": "trust_chip",
      "name": "Trust chip",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Collector-grade packaging"
        }
      ]
    },
    {
      "type": "add_on_card",
      "name": "Add-on card",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Collector sleeve / gift wrap"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price label",
          "default": "$12.00"
        },
        {
          "type": "textarea",
          "id": "copy",
          "label": "Description",
          "default": "Use this slot for a real accessory product, premium packaging, or creator bonus item."
        },
        {
          "type": "text",
          "id": "source_note",
          "label": "Source note",
          "default": "Preview-safe placeholder until Shopify admin wiring is complete."
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "Add-on slot"
        }
      ]
    },
    {
      "type": "benefit",
      "name": "Benefit",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "badge",
          "label": "Badge",
          "default": "Fast ship"
        },
        {
          "type": "textarea",
          "id": "copy",
          "label": "Copy",
          "default": "Use for preorder windows, warehouse location, or customs reassurance."
        }
      ]
    },
    {
      "type": "checklist_item",
      "name": "Checklist item",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Bundle upsell copy"
        },
        {
          "type": "text",
          "id": "status",
          "label": "Status",
          "default": "Easy win"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Main product",
      "blocks": [
        { "type": "trust_chip", "settings": { "label": "Collector-grade packaging" } },
        { "type": "trust_chip", "settings": { "label": "Tracked shipping" } },
        { "type": "trust_chip", "settings": { "label": "Gift note ready" } },
        { "type": "add_on_card", "settings": { "title": "Collector sleeve / gift wrap", "price": "$12.00", "copy": "Use this slot for a real accessory product, premium packaging, or creator bonus item.", "source_note": "Swap this to a metafield-driven product later, or keep it as a manual merchandising card.", "cta_label": "Add-on slot" } },
        { "type": "benefit", "settings": { "badge": "Fast ship", "copy": "Use for preorder windows, warehouse location, or customs reassurance." } },
        { "type": "benefit", "settings": { "badge": "Giftable", "copy": "Call out premium packaging, card inserts, or bundle discounts." } },
        { "type": "benefit", "settings": { "badge": "Collector safe", "copy": "Great slot for material notes, blind box odds, or authenticity cues." } },
        { "type": "checklist_item", "settings": { "label": "Surprise tiers / rarity", "status": "Add later" } },
        { "type": "checklist_item", "settings": { "label": "Restock signup module", "status": "Ready" } },
        { "type": "checklist_item", "settings": { "label": "Bundle upsell copy", "status": "Easy win" } }
      ]
    }
  ]
}
{% endschema %}
