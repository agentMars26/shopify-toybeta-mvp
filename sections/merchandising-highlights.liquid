<section class="section" id="merch-highlights">
  <div class="page-width section-stack">
    <div class="section-heading">
      <div>
        {% if section.settings.eyebrow != blank %}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{% endif %}
        <h2>{{ section.settings.heading }}</h2>
        {% if section.settings.copy != blank %}<div class="text-muted rich-copy">{{ section.settings.copy }}</div>{% endif %}
      </div>
    </div>
    <div class="merch-highlight-grid">
      <article class="merch-highlight-lead">
        {% if section.settings.lead_kicker != blank %}<div class="eyebrow">{{ section.settings.lead_kicker }}</div>{% endif %}
        <h3>{{ section.settings.lead_heading }}</h3>
        <div class="text-muted rich-copy">{{ section.settings.lead_copy }}</div>
        <div class="pill-row">
          {% if section.settings.lead_pill_1 != blank %}<span class="hero-chip">{{ section.settings.lead_pill_1 }}</span>{% endif %}
          {% if section.settings.lead_pill_2 != blank %}<span class="hero-chip">{{ section.settings.lead_pill_2 }}</span>{% endif %}
          {% if section.settings.lead_pill_3 != blank %}<span class="hero-chip">{{ section.settings.lead_pill_3 }}</span>{% endif %}
        </div>
      </article>
      <div class="merch-highlight-stack">
        {% for block in section.blocks %}
          <article class="merch-highlight-card" {{ block.shopify_attributes }}>
            {% if block.settings.kicker != blank %}<div class="eyebrow">{{ block.settings.kicker }}</div>{% endif %}
            <h3>{{ block.settings.heading }}</h3>
            <div class="text-muted rich-copy">{{ block.settings.copy }}</div>
          </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Merchandising highlights",
  "max_blocks": 4,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Featured merchandising blocks" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Make the homepage editable where real merchants actually want control" },
    { "type": "richtext", "id": "copy", "label": "Copy", "default": "<p>This section gives a merchant-friendly home to assortment strategy, gifting cues, and premium tier framing that often changes every launch cycle.</p>" },
    { "type": "text", "id": "lead_kicker", "label": "Lead kicker", "default": "Homepage strategy" },
    { "type": "text", "id": "lead_heading", "label": "Lead heading", "default": "Use one bigger merchandising callout to frame the entire assortment" },
    { "type": "richtext", "id": "lead_copy", "label": "Lead copy", "default": "<p>Good merchants want to rewrite this area often: new gifting angle, fresh price ladder, current launch story, or a push toward collector bundles.</p>" },
    { "type": "text", "id": "lead_pill_1", "label": "Lead pill 1", "default": "Gift picks under $40" },
    { "type": "text", "id": "lead_pill_2", "label": "Lead pill 2", "default": "Core blind box ladder" },
    { "type": "text", "id": "lead_pill_3", "label": "Lead pill 3", "default": "Premium shelf centerpiece" }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "settings": [
        { "type": "text", "id": "kicker", "label": "Kicker", "default": "Giftability" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Surface price ladders early" },
        { "type": "richtext", "id": "copy", "label": "Copy", "default": "<p>Help shoppers self-select from impulse-friendly, core, and premium tiers before they start filtering.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Merchandising highlights",
      "blocks": [
        { "type": "highlight", "settings": { "kicker": "Giftability", "heading": "Surface price ladders early", "copy": "<p>Help shoppers self-select from impulse-friendly, core, and premium tiers before they start filtering.</p>" } },
        { "type": "highlight", "settings": { "kicker": "Storytelling", "heading": "Pair worlds with products", "copy": "<p>Use editable copy to tie characters, artists, or seasonal narratives directly to what is for sale now.</p>" } },
        { "type": "highlight", "settings": { "kicker": "Conversion", "heading": "Keep preorder reassurance close", "copy": "<p>Swap this block as launch timing changes so the homepage always reflects the latest shipping or stock guidance.</p>" } }
      ]
    }
  ]
}
{% endschema %}
