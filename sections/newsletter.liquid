<section class="section">
  <div class="page-width">
    <div class="newsletter-box">
      <div>
        {% if section.settings.eyebrow != blank %}<div class="eyebrow">{{ section.settings.eyebrow }}</div>{% endif %}
        <h2>{{ section.settings.heading }}</h2>
        <div class="text-muted">{{ section.settings.text }}</div>
      </div>
      {% form 'customer', class: 'newsletter-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input class="input" type="email" name="contact[email]" placeholder="{{ section.settings.placeholder }}" required>
        <button class="btn btn-primary" type="submit">{{ section.settings.button_label }}</button>
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Stay in the loop" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Capture restock alerts and VIP drop signups" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Perfect for demo stores that need a simple, credible way to collect demand before launch.</p>" },
    { "type": "text", "id": "placeholder", "label": "Placeholder", "default": "Email address" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Subscribe" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
