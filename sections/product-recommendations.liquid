{% assign related_collection = product.collections.first %}
<section class="section" style="padding-top:0;">
  <div class="page-width">
    <div class="section-heading">
      <div>
        <div class="eyebrow">Pair with</div>
        <h2>{{ section.settings.heading }}</h2>
      </div>
    </div>
    <div class="card-grid">
      {% if related_collection != blank %}
        {% for related_product in related_collection.products limit: 4 %}
          {% if related_product.id != product.id %}
            {% render 'product-card', product: related_product %}
          {% endif %}
        {% endfor %}
      {% else %}
        {% for i in (1..4) %}
          {% render 'product-card-placeholder', index: i %}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product recommendations",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Collectors also viewed" }
  ]
}
{% endschema %}
