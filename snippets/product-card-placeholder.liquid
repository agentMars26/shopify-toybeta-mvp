<article class="card">
  <div class="card-media">{{ 'product-' | append: index | placeholder_svg_tag: 'placeholder-svg' }}</div>
  <div class="card-body">
    <div class="badge">Demo item</div>
    <h3>Collectible figure {{ index }}</h3>
    <div class="text-muted">Vendor name</div>
    <div style="margin-top:.75rem;"><span class="price">$29.00</span></div>
  </div>
</article>
