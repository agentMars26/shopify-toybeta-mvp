<article class="card">
  <div class="card-media">{{ 'product-' | append: index | placeholder_svg_tag: 'placeholder-svg' }}</div>
  <div class="card-body">
    <div class="card-meta">
      <div class="badge">Demo item</div>
      <div class="card-kicker">Collector tier</div>
    </div>
    <h3>Collectible figure {{ index }}</h3>
    <div class="text-muted">Vendor name</div>
    <div class="card-footer">
      <div><span class="price">$29.00</span></div>
      <span class="card-cta">Preview card →</span>
    </div>
    <div class="card-availability">Ready for sample copy</div>
  </div>
</article>
