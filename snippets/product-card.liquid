{% assign first_available_variant = product.selected_or_first_available_variant %}
<article class="card">
  <a class="card-link" href="{{ product.url | within: collection }}">
    <div class="card-media">
      {% if product.featured_image %}
        {{ product.featured_image | image_url: width: 800 | image_tag: alt: product.title, loading: 'lazy' }}
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>
    <div class="card-body">
      <div class="card-meta">
        {% if product.tags.size > 0 %}
          <div class="badge">{{ product.tags.first }}</div>
        {% else %}
          <div class="badge badge-outline">Collector pick</div>
        {% endif %}
        <div class="card-kicker">{{ product.type | default: 'Limited drop' }}</div>
      </div>
      <div class="card-title-row">
        <div>
          <h3>{{ product.title }}</h3>
          <div class="text-muted">{{ product.vendor }}</div>
        </div>
      </div>
      <div class="card-footer">
        <div>
          <span class="price">{{ product.price | money }}</span>
          {% if product.compare_at_price > product.price %}<span class="compare-at">{{ product.compare_at_price | money }}</span>{% endif %}
        </div>
        <span class="card-cta">Quick look →</span>
      </div>
      <div class="card-availability">{% if product.available %}In stock now{% else %}Preorder available{% endif %}</div>
    </div>
  </a>
  <div class="card-actions">
    <a class="btn btn-secondary" href="{{ product.url | within: collection }}">View details</a>
    {% if first_available_variant %}
      {% form 'product', product, class: 'quick-add-form', data-product-form: '' %}
        <input type="hidden" name="id" value="{{ first_available_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <button class="btn btn-primary" type="submit" {% unless product.available %}disabled{% endunless %}>
          {% if product.available %}Quick add{% else %}Sold out{% endif %}
        </button>
      {% endform %}
    {% endif %}
  </div>
</article>
